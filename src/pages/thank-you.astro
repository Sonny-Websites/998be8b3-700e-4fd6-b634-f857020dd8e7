---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '') || '';
---

<BaseLayout
  title="Thank You"
  description="Thank you for your submission."
  ogTitle="Thank You"
  ogDescription="Your message has been sent successfully."
>
  <main class="thank-you" role="main" aria-labelledby="thankHeading">
    <section>
      <h1 id="thankHeading">Thank you.</h1>
      <p>Your message was submitted successfully. We will follow up soon.</p>
      <a href={base + '/'} class="btn btn-primary">Back to Home</a>
    </section>
  </main>
</BaseLayout>
